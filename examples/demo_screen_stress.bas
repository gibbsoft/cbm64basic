10 REM ==========================================
20 REM SCREEN STRESS TEST FOR CBM64 BASIC
30 REM ==========================================
40 PRINT CHR$(147)
50 PRINT "*** SCREEN STRESS TEST ***"
60 PRINT
70 PRINT "THIS PROGRAM TESTS SCREEN CONTROLS"
80 GOSUB 2000
90 PRINT CHR$(147)
100 PRINT "TEST 1: CURSOR MOVEMENT"
110 PRINT "======================="
120 PRINT "MOVING CURSOR AROUND..."
130 PRINT CHR$(19);
140 FOR I = 1 TO 5
150 PRINT CHR$(29); "->";
160 NEXT I
170 PRINT
180 FOR I = 1 TO 3
190 PRINT CHR$(17); "DOWN"
200 NEXT I
210 PRINT
220 GOSUB 2000
230 SCREEN
240 PRINT CHR$(147)
250 PRINT "TEST 2: CLEAR SCREEN"
260 PRINT "==================="
270 PRINT "THIS WILL BE CLEARED..."
280 FOR I = 1 TO 1000 : NEXT I
290 PRINT "SCREEN CLEARED!"
300 PRINT "POSITION IS HOME"
310 PRINT
320 GOSUB 2000
330 SCREEN
340 PRINT CHR$(147)
350 PRINT "TEST 3: SCREEN POKE/PEEK"
360 PRINT "========================"
370 PRINT "POKING CHARACTERS TO SCREEN..."
380 FOR I = 0 TO 39
390 POKE 1024 + I, 65 + (I MOD 26)
400 NEXT I
410 FOR I = 40 TO 79
420 POKE 1024 + I, 48 + (I MOD 10)
430 NEXT I
440 PRINT "SCREEN POKED WITH ALPHANUMERIC"
450 PRINT "PEEKING FIRST 5 BYTES:"
460 FOR I = 0 TO 4
470 PRINT "PEEK("; 1024+I; ") ="; PEEK(1024+I)
480 NEXT I
490 PRINT
500 GOSUB 2000
510 SCREEN
520 PRINT CHR$(147)
530 PRINT "TEST 4: COLOR RAM"
540 PRINT "================="
550 PRINT "SETTING COLORS BY ROW..."
560 FOR ROW = 0 TO 24
570 FOR COL = 0 TO 39
580 COLOR = (ROW + COL) MOD 16
590 POKE 55296 + ROW * 40 + COL, COLOR
600 NEXT COL
610 NEXT ROW
620 PRINT "RAINBOW PATTERN ACROSS SCREEN"
630 PRINT
640 GOSUB 2000
650 SCREEN
660 PRINT CHR$(147)
670 PRINT "TEST 5: STRING FUNCTIONS"
680 PRINT "======================="
690 A$ = "COMMODORE 64"
700 PRINT "A$ ="; A$
710 B$ = LEFT$(A$, 9)
720 PRINT "LEFT$(A$,9) ="; B$
730 C$ = RIGHT$(A$, 5)
740 PRINT "RIGHT$(A$,5) ="; C$
750 PRINT "LEN(A$) ="; LEN(A$)
760 PRINT "STR$(42.5) ="; STR$(42.5)
770 PRINT "CHR$(65) ="; CHR$(65)
780 PRINT "ASC(B) ="; ASC("B")
790 PRINT
800 GOSUB 2000
810 SCREEN
820 PRINT CHR$(147)
830 PRINT "TEST 6: MATH FUNCTIONS"
840 PRINT "====================="
850 PRINT "ABS(-10) ="; ABS(-10)
860 PRINT "SQR(144) ="; SQR(144)
870 PRINT "INT(3.7) ="; INT(3.7)
880 PRINT "SGN(-5) ="; SGN(-5)
890 PRINT "SIN(0) ="; SIN(0)
900 PRINT "COS(0) ="; COS(0)
910 PRINT "LOG(1) ="; LOG(1)
920 PRINT "EXP(0) ="; EXP(0)
930 PRINT
940 GOSUB 2000
950 SCREEN
960 PRINT CHR$(147)
970 PRINT "TEST 7: COLORED PATTERN"
980 PRINT "======================"
990 FOR ROW = 0 TO 24
1000 FOR COL = 0 TO 39
1010 CHAR = 64 + ((ROW + COL) MOD 26)
1020 COLOR = (ROW + COL) MOD 8 + 2
1030 POKE 1024 + ROW * 40 + COL, CHAR
1040 POKE 55296 + ROW * 40 + COL, COLOR
1050 NEXT COL
1060 NEXT ROW
1070 PRINT "COLORED ALPHABET PATTERN"
1080 PRINT
1090 GOSUB 2000
1100 SCREEN
1110 PRINT CHR$(147)
1120 PRINT "*** ALL TESTS COMPLETE ***"
1130 PRINT
1140 PRINT "THANK YOU FOR TESTING!"
1150 PRINT
1160 PRINT "SCREEN CONTROL CODES:"
1170 PRINT "  CHR$(147) - CLEAR SCREEN"
1180 PRINT "  CHR$(17)  - CURSOR DOWN"
1190 PRINT "  CHR$(145) - CURSOR UP"
1200 PRINT "  CHR$(29)  - CURSOR RIGHT"
1210 PRINT "  CHR$(157) - CURSOR LEFT"
1220 PRINT "  CHR$(19)  - HOME CURSOR"
1230 PRINT
1240 PRINT "MEMORY ADDRESSES:"
1250 PRINT "  SCREEN RAM: $0400 = 1024"
1260 PRINT "  COLOR RAM:  $D800 = 55296"
1270 END
1280
